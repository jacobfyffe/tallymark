# The orchestrator runs the full pipeline, so it needs both the database and
# Spotify credentials (for the capture stage). Copy to .env and fill in.

DATABASE_URL=postgres://scrobbler:scrobbler@localhost:5432/scrobbler

# Spotify app credentials (same as the scrobbler used).
SPOTIFY_CLIENT_ID=your_client_id
SPOTIFY_CLIENT_SECRET=your_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:4000/callback

# Schedules (optional — sensible defaults shown).
ORCH_PIPELINE_INTERVAL_MS=60000
ORCH_FINALIZE_CHECK_INTERVAL_MS=3600000
ORCH_CAPTURE_POLL_LIMIT=50

# Personal-chart timezone.
CHART_PERSONAL_TZ=America/New_York

# Copy to .env and fill in. Never commit your real .env.

NODE_ENV=development

# The SAME database Phases 1 and 2 use.
DATABASE_URL=postgres://scrobbler:scrobbler@localhost:5432/scrobbler

# IANA timezone for PERSONAL chart week boundaries (global charts use UTC).
CHART_PERSONAL_TZ=America/New_York

# Max entries per weekly chart.
CHART_SIZE=100

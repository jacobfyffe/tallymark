# Copy to .env and fill in. Never commit your real .env.
NODE_ENV=development
PORT=4000
# The SAME database all prior phases use.
DATABASE_URL=postgres://scrobbler:scrobbler@localhost:5432/scrobbler
# Where the frontend dev server runs (for CORS).
CORS_ORIGIN=http://localhost:5173

# Spotify OAuth — use the same Client ID and Secret as your scrobbler .env.
# The redirect URI goes through the Vite dev proxy so cookies work correctly.
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:5173/callback/spotify

# Session secret — any long random string. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_me_to_a_long_random_string
